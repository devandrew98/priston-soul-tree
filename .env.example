# Compartilhamento por código (função serverless /api/build).
# Crie um banco Redis grátis na Upstash (ou ative o Vercel KV / Marketplace) e
# cole aqui as credenciais REST. Na Vercel, defina estas mesmas variáveis em
# Project Settings -> Environment Variables.
#
# Aceita os nomes da Upstash OU os do Vercel KV (qualquer um dos pares).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---------------------------------------------------------------------------
# Marketplace (Supabase). Crie um projeto grátis em https://supabase.com,
# rode supabase/schema.sql no SQL editor, e cole aqui (Settings -> API):
#   - Project URL     -> VITE_SUPABASE_URL
#   - anon public key -> VITE_SUPABASE_ANON_KEY  (pode ir pro navegador)
# Sem estas variáveis o Marketplace roda no modo demo (dados locais/mock).
# Na Vercel: defina as mesmas em Project Settings -> Environment Variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Somente no SERVIDOR (funções em /api). NUNCA prefixe com VITE_ nem exponha
# no front — dá acesso total ignorando o RLS. Settings -> API -> service_role.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
